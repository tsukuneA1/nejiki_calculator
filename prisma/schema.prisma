generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Pokemon {
  id                   Int                    @id @default(autoincrement())
  name                 String
  hp                   Int
  attack               Int
  defense              Int
  spAttack             Int
  spDefense            Int
  speed                Int
  ability1Id           Int
  ability2Id           Int?
  ability1             Ability                @relation("PokemonAbility1", fields: [ability1Id], references: [id])
  ability2             Ability?               @relation("PokemonAbility2", fields: [ability2Id], references: [id])
  imageSrc             String
  type1                String
  type2                String?
  weight               Float
  battleFactoryPokemon BattleFactoryPokemon[]
}

model Ability {
  id              Int       @id @default(autoincrement())
  name            String    @unique
  pokemonAbility1 Pokemon[] @relation("PokemonAbility1")
  pokemonAbility2 Pokemon[] @relation("PokemonAbility2")
}

model Item {
  id                   Int                    @id @default(autoincrement())
  name                 String                 @unique
  battleFactoryPokemon BattleFactoryPokemon[]
}

model BattleFactoryPokemon {
  id                 Int                        @id @default(autoincrement())
  pokemonId          Int
  itemId             Int?
  pokemon            Pokemon                    @relation(fields: [pokemonId], references: [id])
  item               Item?                      @relation(fields: [itemId], references: [id])
  hpEv               Int
  attackEv           Int
  defenseEv          Int
  spAttackEv         Int
  spDefenseEv        Int
  speedEv            Int
  nature             String
  group              Int
  battleFactoryMoves BattleFactoryPokemonMove[]
}

model Move {
  id                 Int                        @id @default(autoincrement())
  name               String
  type               String
  power              Int?
  accuracy           Int?
  pp                 Int?
  classification     String
  super              Int
  battleFactoryMoves BattleFactoryPokemonMove[]
}

model BattleFactoryPokemonMove {
  id                     Int                  @id @default(autoincrement())
  battleFactoryPokemonId Int
  moveId                 Int
  slot                   Int
  battleFactoryPokemon   BattleFactoryPokemon @relation(fields: [battleFactoryPokemonId], references: [id])
  move                   Move                 @relation(fields: [moveId], references: [id])

  @@unique([battleFactoryPokemonId, slot])
  @@unique([battleFactoryPokemonId, moveId])
}
